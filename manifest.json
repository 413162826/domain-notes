{
  "manifest_version": 3,
  "name": "Domain Notes",
  "version": "1.1.0",
  "description": "每个网站域名一个笔记本，支持 Markdown 快捷键、粘贴图片、深色模式，纯本地存储",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "favicon"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Domain Notes"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
